# =============================================================================
# Obolus backend — environment variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# Server
PORT=4000
NODE_ENV=development

# Database
DB_PATH=./obolus.db

# Solana — treasury wallet + deployed Anchor program
SOLANA_NETWORK=devnet
# SOLANA_RPC_URL=           # Optional: override default devnet/mainnet RPC
SOLANA_TREASURY_SECRET=     # Base58 secret key of treasury wallet
SOLANA_PROGRAM_ID=9CQph7JCyba9uWBRGoDmpiGSnZn2gtvqLBTMF7CYKJzK
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU   # devnet USDC

# VCC fulfillment service (local mini-VCC + Tango Card)
VCC_API_BASE=http://localhost:5000
OBOLUS_BASE_URL=http://localhost:4000
# Secret for HMAC-signed callbacks from VCC — generate with: openssl rand -hex 32
VCC_CALLBACK_SECRET=

# Bags integration
# BAGS_API_KEY=
# BAGS_PROJECT_ID=
# BAGS_TOKEN_MINT=

# AI Agent (Claude)
# ANTHROPIC_API_KEY=

# CORS — comma-separated allowed origins
# CORS_ORIGINS=http://localhost:3000

# Bootstrap owner — first user with this email gets owner role
# OWNER_EMAIL=owner@example.com

# Platform owner — unlocks cross-tenant dashboard surface
# OBOLUS_PLATFORM_OWNER_EMAIL=

# Internal dashboard access — comma-separated emails for /internal/* routes
# INTERNAL_EMAILS=ops@example.com

# Secret-box key — AES-256-GCM, seals card data and claim payloads at rest
# Required in production. Generate with: openssl rand -hex 32
# OBOLUS_SECRET_BOX_KEY=

# SMTP — email delivery for OTPs and alerts (all-or-nothing)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@obolus.xyz

# Recovery job knobs (milliseconds, optional — override defaults)
# STUCK_RETRY_AFTER_MS=120000
# STUCK_FAIL_AFTER_MS=600000
# MAX_FULFILLMENT_ATTEMPTS=3
